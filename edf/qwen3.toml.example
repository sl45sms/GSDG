# Bristen (A100 / x86_64) environment definition.
#
# For Clariden (GH200 / aarch64), use the separate template:
#   edf/qwen3_clariden.toml.example

image = "${SCRATCH}/images/gsdg-qwen3_latest.sqsh"
mounts = ["${SCRATCH}:${SCRATCH}"]
workdir = "${SCRATCH}"

[env]
HF_HOME = "${SCRATCH}/hf"
TRANSFORMERS_CACHE = "${SCRATCH}/hf"
HF_DATASETS_CACHE = "${SCRATCH}/hf_datasets"
# Optional: only required for gated models/datasets.
# If unset, Pyxis may fail variable expansion unless we provide a default.
HF_TOKEN = "${HF_TOKEN:-}"

# Bristen-safe defaults for vLLM distributed startup.
NCCL_SOCKET_IFNAME = "hsn0"
GLOO_SOCKET_IFNAME = "hsn0"
VLLM_HOST_IP = "${VLLM_HOST_IP}"
VLLM_ENABLE_V1_MULTIPROCESSING = "0"
